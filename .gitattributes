# Force LF line endings on Linux-executed files (GitHub Actions runners are Linux)
*.yml        text eol=lf
*.yaml       text eol=lf
*.sh         text eol=lf
*.tf         text eol=lf
*.tfvars     text eol=lf
*.json       text eol=lf
*.md         text eol=lf
Dockerfile   text eol=lf
*.js         text eol=lf

# Keep CRLF for Windows-only files
*.ps1        text eol=crlf
